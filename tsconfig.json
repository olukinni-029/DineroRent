{
  "compilerOptions": {
    "target": "es2015",
    "module": "NodeNext",
    "outDir": "./dist",
    "rootDir": "./src",
    "sourceMap": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "downlevelIteration": true,
    "noImplicitAny": true,
    "ignoreDeprecations": "6.0"
  },
  "include": ["src/**/*", "./api/*.ts"],
  "exclude": ["node_modules", "dist"],
  "files":["src/types/express.d.ts"]
}
